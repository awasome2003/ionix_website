# --- Server ---
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS.
# The Vite dev server defaults to 5173.
CLIENT_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Database ---
# Local Mongo: mongodb://127.0.0.1:27017/ionix
# Atlas:       mongodb+srv://<user>:<pass>@<cluster>/ionix
MONGODB_URI=mongodb://127.0.0.1:27017/ionix

# --- Auth (admin API) ---
# Use a long random string in production: `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Credentials used by `npm run seed:admin` to create the first admin user.
ADMIN_EMAIL=admin@ionix.com
ADMIN_PASSWORD=ChangeThisPassword123!
